						<key>MacroActionType</key>
						<string>ExecuteAppleScript</string>
						<key>Path</key>
						<string></string>
						<key>Text</key>
						<string>set oldTIDs to AppleScript's text item delimitersset AppleScript's text item delimiters to {" ", return, linefeed, tab}set rawList to text items of (the clipboard as text)set AppleScript's text item delimiters to oldTIDsset resultList to {}repeat with itemText in rawList	if itemText is not "" then set end of resultList to (itemText as text)end repeattell application "System Events"	set activeApp to name of first application process whose frontmost is true	activate	set f to (choose from list resultList with multiple selections allowed)end tellset oldTIDs to AppleScript's text item delimitersset AppleScript's text item delimiters to " "set selectedText to f as textset AppleScript's text item delimiters to oldTIDsselectedText</string>
